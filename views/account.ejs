<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title><%= title %> - Account Settings</title>
    <link rel="stylesheet" href="/css/store.css">
    <link rel="stylesheet" href="/css/account.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body data-payment-app-url="<%= paymentAppUrl %>" data-merchant-name="<%= merchantName %>" data-app-base-url="<%= appBaseUrl %>">
    
    <%- include('../partials/navbar.ejs') %>

    <main class="account-shell">
        <div class="account-sidebar">
            <div class="user-avatar">
                <i class="fas fa-user-circle"></i>
                <h3 id="userName">Guest User</h3>
                <p id="userEmail">guest@example.com</p>
            </div>
            <nav class="account-nav">
                <button class="account-nav-btn active" data-tab="profile">
                    <i class="fas fa-user"></i>
                    Profile
                </button>
                <button class="account-nav-btn" data-tab="addresses">
                    <i class="fas fa-map-marker-alt"></i>
                    Addresses
                </button>
                <button class="account-nav-btn" data-tab="payment">
                    <i class="fas fa-credit-card"></i>
                    Payment Methods
                </button>
                <button class="account-nav-btn" data-tab="security">
                    <i class="fas fa-lock"></i>
                    Security
                </button>
                <button class="account-nav-btn" data-tab="preferences">
                    <i class="fas fa-sliders-h"></i>
                    Preferences
                </button>
            </nav>
        </div>

        <div class="account-content">
            <div id="profileTab" class="account-tab active">
                <h2>Profile Information</h2>
                <form id="profileForm" class="account-form">
                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" id="fullName" placeholder="Enter your full name">
                    </div>
                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" id="email" placeholder="Enter your email">
                    </div>
                    <div class="form-group">
                        <label>Phone Number</label>
                        <input type="tel" id="phone" placeholder="Enter your phone number">
                    </div>
                    <button type="submit" class="primary-button">Save Changes</button>
                </form>
            </div>

            <div id="addressesTab" class="account-tab">
                <h2>Saved Addresses</h2>
                <div id="addressesList" class="addresses-list"></div>
                <button id="addAddressBtn" class="secondary-button">
                    <i class="fas fa-plus"></i>
                    Add New Address
                </button>
            </div>

            <div id="paymentTab" class="account-tab">
                <h2>Payment Methods</h2>
                <div id="paymentMethodsList" class="payment-methods-list"></div>
                <button id="addPaymentBtn" class="secondary-button">
                    <i class="fas fa-plus"></i>
                    Add Payment Method
                </button>
            </div>

            <div id="securityTab" class="account-tab">
                <h2>Security Settings</h2>
                <form id="securityForm" class="account-form">
                    <div class="form-group">
                        <label>Current Password</label>
                        <input type="password" id="currentPassword" placeholder="Enter current password">
                    </div>
                    <div class="form-group">
                        <label>New Password</label>
                        <input type="password" id="newPassword" placeholder="Enter new password">
                    </div>
                    <div class="form-group">
                        <label>Confirm New Password</label>
                        <input type="password" id="confirmPassword" placeholder="Confirm new password">
                    </div>
                    <button type="submit" class="primary-button">Update Password</button>
                </form>
            </div>

            <div id="preferencesTab" class="account-tab">
                <h2>Preferences</h2>
                <form id="preferencesForm" class="account-form">
                    <div class="form-group">
                        <label>
                            <input type="checkbox" id="newsletter"> Subscribe to newsletter
                        </label>
                    </div>
                    <div class="form-group">
                        <label>
                            <input type="checkbox" id="orderUpdates"> Receive order updates via email
                        </label>
                    </div>
                    <div class="form-group">
                        <label>Currency Preference</label>
                        <select id="currency">
                            <option value="USD">USD - US Dollar</option>
                            <option value="EUR">EUR - Euro</option>
                            <option value="GBP">GBP - British Pound</option>
                        </select>
                    </div>
                    <button type="submit" class="primary-button">Save Preferences</button>
                </form>
            </div>
        </div>
    </main>

    <%- include('../partials/bottom-nav.ejs') %>

    <script src="/js/account.js"></script>
</body>
</html>
      
      