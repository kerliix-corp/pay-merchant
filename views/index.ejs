<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/store.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body data-payment-app-url="<%= paymentAppUrl %>" data-merchant-name="<%= merchantName %>" data-app-base-url="<%= appBaseUrl %>">
    
    <%- include('partials/navbar.ejs') %>

<header class="hero">
    <div class="hero-copy">
        <p class="eyebrow">
            <i class="fas fa-bolt"></i>
            Fast. Trusted. Affordable.
        </p>

        <h1>Shop smarter with Kerliix</h1>

        <p class="lede">
            Discover top deals on electronics, fashion, and more — all in one place.
        </p>
    </div>
</header>

    <main class="catalog-shell">
        <div class="catalog-filters">
            <div class="filter-group">
                <label for="categoryFilter" class="filter-label">
                    <i class="fas fa-filter"></i>
                    Category
                </label>
                <select id="categoryFilter" class="filter-select">
                    <option value="all">All Categories</option>
                </select>
            </div>
            <div class="filter-group">
                <label for="retailerFilter" class="filter-label">
                    <i class="fas fa-store"></i>
                    Retailer
                </label>
                <select id="retailerFilter" class="filter-select">
                    <option value="all">All Retailers</option>
                </select>
            </div>
            <button id="resetFilters" class="reset-filters-btn">
                <i class="fas fa-undo-alt"></i>
                Reset
            </button>
        </div>

        <div id="productCategories"></div>
    </main>

    <%- include('partials/bottom-nav.ejs') %>

    <script>
        window.__STORE_PRODUCTS__ = <%- JSON.stringify(products) %>;
    </script>
    <script src="/js/store.js"></script>
</body>
</html>
        