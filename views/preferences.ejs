<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title><%= title %> - Preferences</title>
    <link rel="stylesheet" href="/css/store.css">
    <link rel="stylesheet" href="/css/account.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body data-payment-app-url="<%= paymentAppUrl %>" data-merchant-name="<%= merchantName %>" data-app-base-url="<%= appBaseUrl %>">

    <%- include('partials/navbar.ejs') %>

    <main class="account-shell" style="grid-template-columns: 1fr;">
        <div class="account-content">
            <section class="account-tab active">
                <h2>Preferences</h2>

                <form id="preferencesForm" class="account-form">
                    <label class="form-group" for="newsletter">
                        <span>Newsletter</span>
                        <input id="newsletter" name="newsletter" type="checkbox">
                    </label>

                    <label class="form-group" for="orderUpdates">
                        <span>Order Updates</span>
                        <input id="orderUpdates" name="orderUpdates" type="checkbox">
                    </label>

                    <div class="form-group">
                        <label for="currency">Preferred Currency</label>
                        <select id="currency" name="currency">
                            <option value="UGX">UGX</option>
                        </select>
                    </div>

                    <button type="submit" class="secondary-button">
                        <i class="fas fa-sliders-h"></i>
                        Save Preferences
                    </button>
                </form>
            </section>
        </div>
    </main>

    <%- include('partials/bottom-nav.ejs') %>

    <script>
        window.__ACCOUNT_DATA__ = <%- JSON.stringify(accountData || null) %>;
    </script>
    <script src="/js/account.js"></script>
</body>
</html>
