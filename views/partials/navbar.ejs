<nav class="topbar">
    <div class="nav-container">
        <a href="/" class="brand">
            <i class="fas fa-store"></i>
            <%= merchantName %>
        </a>

        <div class="mobile-actions">
            <a href="/cart" class="cart-link mobile-cart-link" aria-label="Cart">
                <i class="fas fa-shopping-cart"></i>
                <span id="mobileCartBadge" class="cart-badge">0</span>
            </a>

            <button class="mobile-menu-toggle" aria-label="Menu">
                <i class="fas fa-bars"></i>
            </button>
        </div>

        <div class="nav-actions">
            <a href="/search" class="nav-icon">
                <i class="fas fa-search"></i>
            </a>

            <a href="/cart" class="cart-link">
                <i class="fas fa-shopping-cart"></i>
                <span id="cartCountBadge" class="cart-badge">0</span>
            </a>

            <a href="/user/notifications" class="nav-icon">
                <i class="fas fa-bell"></i>
            </a>

            <a href="/user/profile" class="nav-icon">
                <% if (currentUser) { %>
                    <span class="nav-avatar-initials"><%= currentUser.initials %></span>
                <% } else { %>
                    <i class="fas fa-user-circle"></i>
                <% } %>
            </a>
        </div>
    </div>
</nav>

<div class="mobile-menu">
    <div class="mobile-menu-inner">
        <div class="mobile-menu-header">
            <span class="mobile-menu-title">Menu</span>
        </div>
        <a href="/search" class="mobile-link">
            <i class="fas fa-search"></i>
            <span>Search</span>
        </a>
        <a href="/user/notifications" class="mobile-link">
            <i class="fas fa-bell"></i>
            <span>Notifications</span>
        </a>
        <a href="/user/profile" class="mobile-link">
            <% if (currentUser) { %>
                <span class="mobile-avatar-initials"><%= currentUser.initials %></span>
            <% } else { %>
                <i class="fas fa-user-circle"></i>
            <% } %>
            <span><%= currentUser ? currentUser.fullName : 'Profile' %></span>
        </a>
    </div>
</div>
