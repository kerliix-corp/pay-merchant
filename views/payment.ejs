<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title><%= title %> - Payment Methods</title>
    <link rel="stylesheet" href="/css/store.css">
    <link rel="stylesheet" href="/css/account.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body data-payment-app-url="<%= paymentAppUrl %>" data-merchant-name="<%= merchantName %>" data-app-base-url="<%= appBaseUrl %>">

    <%- include('partials/navbar.ejs') %>

    <main class="account-shell" style="grid-template-columns: 1fr;">
        <div class="account-content">
            <section class="account-tab active">
                <h2>Payment Methods</h2>

                <div id="paymentMethodsList" class="payment-methods-list"></div>

                <button id="addPaymentBtn" type="button" class="secondary-button">
                    <i class="fas fa-plus"></i>
                    Add Payment Method
                </button>
            </section>
        </div>
    </main>

    <%- include('partials/bottom-nav.ejs') %>

    <script src="/js/account.js"></script>
</body>
</html>
