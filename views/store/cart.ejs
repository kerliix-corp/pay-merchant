<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/store.css">
</head>
<body data-payment-app-url="<%= paymentAppUrl %>" data-merchant-name="<%= merchantName %>" data-app-base-url="<%= appBaseUrl %>">
    <header class="cart-hero">
        <div class="hero-copy compact">
            <p class="eyebrow">Cart review</p>
            <h1>Verify your order.</h1>
        </div>
    </header>

    <main class="cart-layout">
        <section class="cart-items-panel">
            <div class="catalog-header">
                <div>
                    <p class="section-label">Cart</p>
                    <h2>Your selected items</h2>
                </div>
            </div>
            <div id="cartItems" class="cart-items"></div>
            <div id="emptyCartState" class="empty-state" hidden>
                <h3>Your cart is empty</h3>
                <p>Add products from the items page, then come back here to continue.</p>
                <a href="/" class="primary-button inline-button">Browse items</a>
            </div>
        </section>

        <aside class="summary-panel">
            <p class="section-label">Checkout</p>
            <h2>Order summary</h2>

            <div class="summary-list">
                <div class="summary-row">
                    <span>Items</span>
                    <strong id="summaryItems">0</strong>
                </div>
                <div class="summary-row">
                    <span>Subtotal</span>
                    <strong id="summarySubtotal">$0.00</strong>
                </div>
                <div class="summary-row total">
                    <span>Total</span>
                    <strong id="summaryTotal">$0.00</strong>
                </div>
            </div>

            <p class="checkout-note">Customer name, email, and phone number will be entered on the Kerliix Pay checkout page.</p>

            <button id="checkoutBtn" class="primary-button checkout-button">Proceed to payment</button>
            <p id="checkoutMessage" class="checkout-message"></p>
        </aside>
    </main>

    <script>
        window.__STORE_PRODUCTS__ = <%- JSON.stringify(products) %>;
    </script>
    <script src="/js/store.js"></script>
</body>
</html>
