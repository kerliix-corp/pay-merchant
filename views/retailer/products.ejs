<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/store.css">
    <link rel="stylesheet" href="/css/retailer.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('../partials/retailer-navbar.ejs') %>

    <main class="retailer-shell">
        <section class="retailer-page-header">
            <div>
                <p class="retailer-eyebrow">Products</p>
                <h1>Catalog for <%= retailerName %></h1>
            </div>
            <div class="retailer-hero-card compact">
                <span>Live products</span>
                <strong><%= retailerMetrics.productCount %></strong>
            </div>
        </section>

        <section class="retailer-cards-grid">
            <% if (!retailerProducts.length) { %>
                <article class="retailer-panel">
                    <p class="retailer-empty">No retailer products found yet.</p>
                </article>
            <% } %>

            <% retailerProducts.forEach(product => { %>
                <article class="retailer-panel product-card">
                    <div class="retailer-product-meta">
                        <span class="retailer-badge"><%= product.category %></span>
                        <span class="<%= Number(product.stockCount || 0) <= 20 ? 'retailer-alert' : 'retailer-ok' %>">
                            <%= Number(product.stockCount || 0) <= 20 ? 'Low stock' : 'Healthy stock' %>
                        </span>
                    </div>
                    <h2><%= product.name %></h2>
                    <p><%= product.description %></p>
                    <div class="retailer-keyline">
                        <strong><%= formatCurrency(product.price * currencyRate, currencyCode) %></strong>
                        <span><%= product.stockCount %> in stock</span>
                    </div>
                </article>
            <% }) %>
        </section>
    </main>

    <%- include('../partials/retailer-bottom-nav.ejs') %>
</body>
</html>
