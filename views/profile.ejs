<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title><%= title %> - Profile</title>
    <link rel="stylesheet" href="/css/store.css">
    <link rel="stylesheet" href="/css/account.css">
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body data-payment-app-url="<%= paymentAppUrl %>" data-merchant-name="<%= merchantName %>" data-app-base-url="<%= appBaseUrl %>">
    <%- include('partials/navbar.ejs') %>

    <main class="account-shell" style="grid-template-columns: 1fr;">
        <div class="account-content">
            <section class="account-tab active">
                <h2>Profile Navigation</h2>
                <nav class="account-nav">
                    <a href="/user/account" class="account-nav-btn">
                        <i class="fas fa-grid-2"></i>
                        Account Overview
                    </a>
                    <a href="/user/orders" class="account-nav-btn">
                        <i class="fas fa-receipt"></i>
                        My Orders
                    </a>
                    <a href="/user/addresses" class="account-nav-btn">
                        <i class="fas fa-map-marker-alt"></i>
                        Addresses
                    </a>
                    <a href="/user/payment" class="account-nav-btn">
                        <i class="fas fa-credit-card"></i>
                        Payment Methods
                    </a>
                    <a href="/user/security" class="account-nav-btn">
                        <i class="fas fa-lock"></i>
                        Security
                    </a>
                    <a href="/user/preferences" class="account-nav-btn">
                        <i class="fas fa-sliders-h"></i>
                        Preferences
                    </a>
                    <a href="/retailer/dashboard" class="account-nav-btn">
                        <i class="fas fa-store"></i>
                        Retailer Dashboard
                    </a>
                </nav>
            </section>
        </div>
    </main>

    <%- include('partials/bottom-nav.ejs') %>
</body>
</html>
